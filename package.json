{
  "name": "glowing-telegram-frontend",
  "license": "AGPL-3.0-only",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start": "vite",
    "build": "tsc && vite build",
    "serve": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "biome": "biome",
    "biome:ci": "biome ci --reporter=github",
    "lint": "biome lint",
    "lint:vscode": "biome lint --reporter=github",
    "lint:fix": "biome lint --write",
    "format": "biome check --write",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "@mui/icons-material": "^7",
    "@mui/material": "^7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@mui/x-date-pickers": "^8",
    "@saebyn/glowing-telegram-types": ">=0.11.2",
    "@saebyn/glowing-telegram-video-editor": ">=0.3.0",
    "@storybook/addon-docs": "10.2.13",
    "@storybook/addon-links": "10.2.13",
    "@storybook/addon-onboarding": "10.2.13",
    "@storybook/react-vite": "10.2.13",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/luxon": "^3.6.2",
    "@types/md5": "^2.3.5",
    "@types/node": "^25.3.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "@vvo/tzdb": "^6.198.0",
    "autoprefixer": "^10.4.23",
    "iso-639-1": "^3.1.5",
    "jsdom": "^28.0.0",
    "luxon": "^3.6.1",
    "md5": "^2.3.0",
    "msw": "^2.12.10",
    "oidc-client-ts": "^3.2.1",
    "postcss": "^8.5.6",
    "ra-input-rich-text": "^5.6.3",
    "react": "19.2.4",
    "react-admin": "^5.14.3",
    "react-dom": "19.1.0",
    "storybook": "10.2.13",
    "tailwindcss": "^4.2.0",
    "typescript": "^5",
    "vite": "^7.3.1",
    "vitest": "^4"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/saebyn/glowing-telegram-frontend.git"
  }
}
